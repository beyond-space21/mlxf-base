/cpp
#include <nlohmann/json.hpp>
using json = nlohmann::json;

// 1) Typed C++ args (auto-bound by name/position)
int add(int a, int b) {
    return a + b;
}

// 2) JSON-style C++ args (manual extraction still works)
json cpp_add_json(const json& args) {
    int a = args.value("a", 0);
    int b = args.value("b", 0);
    return {{"result", a + b}, {"from", "cpp_json"}};
}

// 3) No-arg C++ function
std::string cpp_banner() {
    return "C++ ready";
}

/py
def py_multiply(a, b):
    return a * b

def pipeline(a, b, name):
    # Direct calls to cross-language functions via installed proxies.
    total = add(a, b)                  # C++
    msg = js_greet(name)               # JS
    return {"sum": total, "greet": msg}

def use_runtime_call_compat(a, b):
    # Backward-compatible style still works.
    return runtime.call("cpp_add_json", {"a": a, "b": b})

/js
function js_greet(name) {
    return "Hello " + name + " from JavaScript!";
}

function js_mul(a, b) {
    return a * b;
}

/main
print("=== PolyRun Capability Demo ===")

print("cpp_banner() =>", cpp_banner())
print("add(40, 2) =>", add(40, 2))
print("js_mul(6, 7) =>", js_mul(6, 7))
print("py_multiply(6, 7) =>", py_multiply(6, 7))

obj = pipeline(10, 32, "PolyRun")
print("pipeline(...) =>", obj)

compat = use_runtime_call_compat(4, 5)
print("runtime.call compatibility =>", compat)

print("DONE")
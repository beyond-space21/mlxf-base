/cpp
#include <nlohmann/json.hpp>
using json = nlohmann::json;

std::string banner() {
    return "PolyRun C++ online (legacy)";
}

int add(int a, int b) {
    return a + b;
}

json cpp_heavy(const json& args) {
    int x = args.value("x", 0);
    int y = args.value("y", 0);
    return {{"product", x * y}, {"sum", x + y}, {"tag", "cpp_heavy_legacy"}};
}

/py
def py_multiply(a, b):
    return a * b

def pipeline(a, b, name):
    total = add(a, b)                  # direct C++ call
    msg   = js_greet(name)             # direct JS call
    heavy = cpp_heavy({"x": 5, "y": 6})
    return {"result": total, "greet": msg, "heavy": heavy}

def use_runtime_call_compat(a, b):
    return runtime.call("add", {"a": a, "b": b})

/js
function js_greet(name) {
    return "Hello " + name + " from JavaScript! (legacy)";
}

function js_mul(a, b) {
    return a * b;
}

/main
print("=== PolyRun LEGACY Demo (old /cpp format) ===")

print("banner() =>", banner())
print("add(40, 2) =>", add(40, 2))
print("js_mul(6, 7) =>", js_mul(6, 7))
print("py_multiply(6, 7) =>", py_multiply(6, 7))

obj = pipeline(10, 10, "Rajanand")
print("pipeline(...) =>", obj)

compat = use_runtime_call_compat(2, 2)
print("runtime.call(add) =>", compat)

print("✅ LEGACY MODE WORKS PERFECTLY")